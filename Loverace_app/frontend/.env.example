# API base URL (REST microservice)
VITE_API_URL=http://localhost:8000

# WebSocket base URL (realtime gateway)
VITE_WS_URL=ws://localhost:8001

# Set to "true" to run in demo/dummy-data mode (no backend required)
VITE_DUMMY_DATA=true

# MapLibre GL map style URL (optional — radar shows grid overlay if omitted)
# Free options: https://tiles.openfreemap.org/styles/liberty
# Or Maptiler: https://api.maptiler.com/maps/streets/style.json?key=YOUR_KEY
VITE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
