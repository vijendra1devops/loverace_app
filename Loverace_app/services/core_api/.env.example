DATABASE_URL=postgresql+asyncpg://loverace:pass@localhost/loverace
ASYNCPG_URL=postgresql://loverace:pass@localhost/loverace
# For local development you can use SQLite instead. Uncomment the two
# lines below (and comment out the Postgres values above) to use a
# local `dev.db` file and disable Postgres-only features.
# DATABASE_URL=sqlite+aiosqlite:///./dev.db
# ASYNCPG_URL=
JWT_SECRET=changeme_replace_with_32_plus_chars_in_prod
JWT_EXPIRY_MINUTES=60
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=loverace-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MODERATION_ENABLED=false
DEBUG=true
PG_NOTIFY_CHANNEL=loverace_events
